[Unit]
Description=FastAPI S3 Images Service
After=network-online.target
Wants=network-online.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/punto2Final
Environment="S3_BUCKET=pedro-final-fastapi-punto2"
Environment="AWS_REGION=us-east-2"
ExecStart=/home/ubuntu/punto2Final/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target